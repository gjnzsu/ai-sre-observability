{
  "dashboard": {
    "id": null,
    "uid": "ai-sre-request-tracing",
    "title": "AI SRE Observability - Request Tracing",
    "tags": ["ai-sre", "observability", "tracing", "requests"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
    },
    "panels": [
      {
        "id": 1,
        "type": "nodeGraph",
        "title": "Request Flow by Service",
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 12,
          "h": 10
        },
        "targets": [
          {
            "expr": "sum by (source_service, target_service)(rate(service_requests_total[5m]))",
            "refId": "A",
            "format": "table"
          }
        ],
        "options": {
          "nodes": {
            "mainStatUnit": "reqps"
          },
          "edges": {
            "mainStatUnit": "reqps"
          }
        },
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            }
          }
        }
      },
      {
        "id": 2,
        "type": "table",
        "title": "Trace ID Search",
        "gridPos": {
          "x": 12,
          "y": 0,
          "w": 12,
          "h": 10
        },
        "targets": [
          {
            "expr": "topk(100, llm_request_duration_seconds_sum{trace_id=~\".*\"})",
            "refId": "A",
            "format": "table",
            "instant": true
          }
        ],
        "options": {
          "showHeader": true,
          "sortBy": [
            {
              "displayName": "Time",
              "desc": true
            }
          ]
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "align": "left",
              "filterable": true
            }
          },
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "trace_id"
              },
              "properties": [
                {
                  "id": "custom.width",
                  "value": 300
                },
                {
                  "id": "links",
                  "value": [
                    {
                      "title": "View Trace",
                      "url": "/explore?left={\"queries\":[{\"expr\":\"trace_id=${__value.raw}\"}]}"
                    }
                  ]
                }
              ]
            }
          ]
        },
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "__name__": true,
                "job": true,
                "instance": true
              },
              "indexByName": {
                "trace_id": 0,
                "service_name": 1,
                "provider": 2,
                "model": 3,
                "Value": 4
              },
              "renameByName": {
                "Value": "Duration (s)"
              }
            }
          }
        ]
      },
      {
        "id": 3,
        "type": "heatmap",
        "title": "Request Latency by Service",
        "gridPos": {
          "x": 0,
          "y": 10,
          "w": 24,
          "h": 8
        },
        "targets": [
          {
            "expr": "sum by (le, service_name)(rate(llm_request_duration_seconds_bucket[5m]))",
            "refId": "A",
            "format": "heatmap",
            "legendFormat": "{{service_name}}"
          }
        ],
        "options": {
          "calculate": false,
          "calculation": {},
          "cellGap": 2,
          "cellRadius": 0,
          "color": {
            "exponent": 0.5,
            "fill": "dark-orange",
            "mode": "scheme",
            "reverse": false,
            "scale": "exponential",
            "scheme": "Spectral",
            "steps": 128
          },
          "exemplars": {
            "color": "rgba(255,0,255,0.7)"
          },
          "filterValues": {
            "le": 1e-9
          },
          "legend": {
            "show": true
          },
          "rowsFrame": {
            "layout": "auto"
          },
          "tooltip": {
            "show": true,
            "yHistogram": false
          },
          "yAxis": {
            "axisPlacement": "left",
            "reverse": false,
            "unit": "s"
          }
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "hideFrom": {
                "tooltip": false,
                "viz": false,
                "legend": false
              },
              "scaleDistribution": {
                "type": "linear"
              }
            }
          }
        }
      },
      {
        "id": 4,
        "type": "table",
        "title": "Top Slowest Requests",
        "gridPos": {
          "x": 0,
          "y": 18,
          "w": 24,
          "h": 8
        },
        "targets": [
          {
            "expr": "topk(10, llm_request_duration_seconds_sum)",
            "refId": "A",
            "format": "table",
            "instant": true
          }
        ],
        "options": {
          "showHeader": true,
          "sortBy": [
            {
              "displayName": "Duration (s)",
              "desc": true
            }
          ]
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "align": "left",
              "filterable": true
            }
          },
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "trace_id"
              },
              "properties": [
                {
                  "id": "custom.width",
                  "value": 300
                },
                {
                  "id": "links",
                  "value": [
                    {
                      "title": "View Trace",
                      "url": "/explore?left={\"queries\":[{\"expr\":\"trace_id=${__value.raw}\"}]}"
                    }
                  ]
                }
              ]
            },
            {
              "matcher": {
                "id": "byName",
                "options": "Value"
              },
              "properties": [
                {
                  "id": "unit",
                  "value": "s"
                },
                {
                  "id": "decimals",
                  "value": 3
                },
                {
                  "id": "custom.width",
                  "value": 120
                }
              ]
            }
          ]
        },
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "__name__": true,
                "job": true,
                "instance": true
              },
              "indexByName": {
                "trace_id": 0,
                "service_name": 1,
                "provider": 2,
                "model": 3,
                "Value": 4
              },
              "renameByName": {
                "Value": "Duration (s)",
                "service_name": "Service",
                "provider": "Provider",
                "model": "Model",
                "trace_id": "Trace ID"
              }
            }
          }
        ]
      },
      {
        "id": 5,
        "type": "graph",
        "title": "Request Success Rate",
        "gridPos": {
          "x": 0,
          "y": 26,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "sum by (service_name)(rate(llm_requests_total{status=\"success\"}[5m])) / sum by (service_name)(rate(llm_requests_total[5m])) * 100",
            "refId": "A",
            "legendFormat": "{{service_name}}"
          }
        ],
        "yaxes": [
          {
            "format": "percent",
            "label": "Success Rate",
            "min": 0,
            "max": 100
          },
          {
            "format": "short"
          }
        ],
        "xaxis": {
          "mode": "time"
        },
        "lines": true,
        "fill": 1,
        "linewidth": 2,
        "pointradius": 5,
        "legend": {
          "show": true,
          "alignAsTable": true,
          "avg": true,
          "current": true,
          "min": true,
          "values": true
        },
        "alert": {
          "conditions": [
            {
              "evaluator": {
                "params": [95],
                "type": "lt"
              },
              "operator": {
                "type": "and"
              },
              "query": {
                "params": ["A", "5m", "now"]
              },
              "reducer": {
                "params": [],
                "type": "avg"
              },
              "type": "query"
            }
          ],
          "executionErrorState": "alerting",
          "frequency": "1m",
          "handler": 1,
          "name": "Low Success Rate Alert",
          "noDataState": "no_data",
          "notifications": []
        },
        "thresholds": [
          {
            "value": 95,
            "colorMode": "critical",
            "op": "lt",
            "fill": true,
            "line": true
          }
        ]
      },
      {
        "id": 6,
        "type": "graph",
        "title": "Concurrent Requests",
        "gridPos": {
          "x": 12,
          "y": 26,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "sum by (service_name)(llm_requests_in_flight)",
            "refId": "A",
            "legendFormat": "{{service_name}}"
          }
        ],
        "yaxes": [
          {
            "format": "short",
            "label": "Concurrent Requests",
            "min": 0
          },
          {
            "format": "short"
          }
        ],
        "xaxis": {
          "mode": "time"
        },
        "lines": true,
        "fill": 1,
        "linewidth": 2,
        "pointradius": 5,
        "legend": {
          "show": true,
          "alignAsTable": true,
          "avg": true,
          "current": true,
          "max": true,
          "values": true
        },
        "tooltip": {
          "shared": true,
          "sort": 2,
          "value_type": "individual"
        }
      }
    ],
    "annotations": {
      "list": [
        {
          "builtIn": 1,
          "datasource": "-- Grafana --",
          "enable": true,
          "hide": true,
          "iconColor": "rgba(0, 211, 255, 1)",
          "name": "Annotations & Alerts",
          "type": "dashboard"
        }
      ]
    }
  }
}
